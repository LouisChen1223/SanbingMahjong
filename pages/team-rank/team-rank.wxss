/* pages/team-rank/team-rank.wxss - 团队赛排行榜页面样式 */

/* 全局样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
  box-sizing: border-box;
  padding-bottom: 120rpx;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
  padding: 20rpx 0;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
}

.back-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  flex: 1;
  text-align: center;
  margin: 0 20rpx;
}

.header-btns {
  display: flex;
  gap: 20rpx;
}

.refresh-btn, .clear-btn {
  padding: 16rpx 32rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 30rpx;
  color: #fff;
  font-size: 28rpx;
}

/* 榜单项切换标签 */
.rank-type-tabs {
  display: flex;
  gap: 10rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.rank-type-tab {
  flex: 1;
  min-width: 200rpx;
  padding: 20rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 30rpx;
  text-align: center;
  color: #fff;
  font-size: 28rpx;
  transition: all 0.3s ease;
  font-weight: bold;
}

.rank-type-tab.active {
  background: rgba(255,255,255,0.3);
}

/* 标签容器 */
.tab-container {
  display: flex;
  gap: 10rpx;
  margin-bottom: 30rpx;
  flex-wrap: wrap;
}

.tab {
  flex: 1;
  min-width: 150rpx;
  padding: 20rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 30rpx;
  text-align: center;
  color: #fff;
  font-size: 28rpx;
  transition: all 0.3s ease;
}

.tab.active {
  background: rgba(255,255,255,0.3);
  font-weight: bold;
}

/* 排行榜列表 */
.rank-list {
  background: rgba(255,255,255,0.1);
  border-radius: 20rpx;
  padding: 20rpx;
  backdrop-filter: blur(10rpx);
  margin-bottom: 30rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 15rpx;
  margin-bottom: 15rpx;
  transition: all 0.3s ease;
}

.rank-item:hover {
  background: rgba(255,255,255,0.1);
}

.rank-item.top-1 {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
}

.rank-item.top-2 {
  background: linear-gradient(135deg, #C0C0C0 0%, #A9A9A9 100%);
}

.rank-item.top-3 {
  background: linear-gradient(135deg, #CD7F32 0%, #B8860B 100%);
}

.rank-badge {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.medal {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

.normal-rank {
  font-size: 28rpx;
  color: #fff;
}

.player-info {
  flex: 1;
  min-width: 0;
}

.player-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
  display: block;
}

.games-count {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.positions-count {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
  line-height: 1.3;
}

.score-section {
  text-align: right;
  min-width: 150rpx;
}

.total-score {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  display: block;
}

.total-score.positive {
  color: #4CAF50;
  text-shadow: 0 2rpx 4rpx rgba(76, 175, 80, 0.3);
}

.total-score.negative {
  color: #F44336;
  text-shadow: 0 2rpx 4rpx rgba(244, 67, 54, 0.3);
}

.rate-score {
  font-size: 36rpx;
  font-weight: bold;
  color: #2196F3;
  margin-bottom: 8rpx;
  display: block;
  text-shadow: 0 2rpx 4rpx rgba(33, 150, 243, 0.3);
}

.score-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 20rpx;
  color: rgba(255,255,255,0.8);
}

.empty-text {
  font-size: 32rpx;
  margin-bottom: 20rpx;
  display: block;
}

.empty-hint {
  font-size: 24rpx;
  opacity: 0.7;
}

/* 连接状态 */
.connection-status {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 30rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #F44336;
  animation: pulse 2s infinite;
}

.status-dot.connected {
  background: #4CAF50;
  animation: none;
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.5; }
  100% { opacity: 1; }
}

/* 底部导航栏 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1rpx solid #e8e8e8;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20rpx 0;
  z-index: 999;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx;
  width: 25%;
}

.nav-item.active {
  color: #667eea;
}

.nav-icon {
  font-size: 40rpx;
}

.nav-text {
  font-size: 24rpx;
}