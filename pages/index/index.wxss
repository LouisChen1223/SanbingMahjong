/* index.wxss - 录入页面样式 */
.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1AAD19;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #888;
}

.input-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.player-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.player-row:last-child {
  border-bottom: none;
}

.rank-label {
  width: 80rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #1AAD19;
}

.name-input {
  flex: 1;
  height: 70rpx;
  padding: 0 20rpx;
  margin-right: 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.score-input-wrapper {
  display: flex;
  align-items: center;
}

.score-input {
  width: 120rpx;
  height: 70rpx;
  padding: 0 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx 0 0 8rpx;
  font-size: 28rpx;
  text-align: center;
}

.score-suffix {
  height: 70rpx;
  line-height: 70rpx;
  padding: 0 16rpx;
  background: #f0f0f0;
  border: 1rpx solid #ddd;
  border-left: none;
  border-radius: 0 8rpx 8rpx 0;
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.settle-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: linear-gradient(135deg, #1AAD19, #179B16);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 45rpx;
  border: none;
  margin-top: 20rpx;
}

.settle-btn:active {
  opacity: 0.8;
}

.result-section {
  margin-top: 40rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.result-row:last-child {
  border-bottom: none;
}

.result-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  width: 120rpx;
}

.result-detail {
  flex: 1;
  font-size: 24rpx;
  color: #888;
  text-align: center;
}

.result-final {
  font-size: 32rpx;
  font-weight: bold;
  width: 100rpx;
  text-align: right;
}

.result-final.positive {
  color: #1AAD19;
}

.result-final.negative {
  color: #E64340;
}