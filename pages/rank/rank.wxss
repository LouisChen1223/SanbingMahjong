/* rank.wxss - 排行榜页面样式 */
.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1AAD19;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #888;
}

.rank-list {
  margin-bottom: 30rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.rank-item.top-1 {
  background: linear-gradient(135deg, #FFD700, #FFA500);
}

.rank-item.top-2 {
  background: linear-gradient(135deg, #C0C0C0, #A8A8A8);
}

.rank-item.top-3 {
  background: linear-gradient(135deg, #CD7F32, #B87333);
}

.rank-item.top-1 .player-name,
.rank-item.top-2 .player-name,
.rank-item.top-3 .player-name {
  color: #fff;
}

.rank-item.top-1 .games-count,
.rank-item.top-2 .games-count,
.rank-item.top-3 .games-count {
  color: rgba(255,255,255,0.8);
}

.rank-badge {
  width: 60rpx;
  display: flex;
  justify-content: center;
}

.medal {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  background: #fff;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: bold;
  color: #1AAD19;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.normal-rank {
  font-size: 32rpx;
  font-weight: bold;
  color: #999;
}

.player-info {
  flex: 1;
  margin-left: 20rpx;
}

.player-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.games-count {
  font-size: 24rpx;
  color: #888;
}

.score-section {
  text-align: right;
}

.total-score {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
}

.total-score.positive {
  color: #1AAD19;
}

.total-score.negative {
  color: #E64340;
}

.rank-item.top-1 .total-score,
.rank-item.top-2 .total-score,
.rank-item.top-3 .total-score {
  color: #fff;
}

.score-label {
  font-size: 22rpx;
  color: #888;
}

.rank-item.top-1 .score-label,
.rank-item.top-2 .score-label,
.rank-item.top-3 .score-label {
  color: rgba(255,255,255,0.8);
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}

.connection-status {
  position: fixed;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  background: rgba(0,0,0,0.6);
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.status-dot.connected {
  background: #1AAD19;
}

.status-dot.disconnected {
  background: #E64340;
}

.status-text {
  font-size: 22rpx;
  color: #fff;
}