/* pages/team-manage/team-manage.wxss */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  flex: 1;
  text-align: center;
}

.header-btns {
  display: flex;
  gap: 20rpx;
}


.clear-btn {
  padding: 16rpx 32rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 30rpx;
  color: #fff;
  font-size: 28rpx;
}

.team-list {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
  display: block;
}

.team-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 25rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.team-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 20rpx;
}

.team-id {
  font-size: 28rpx;
  color: #667eea;
  font-weight: bold;
  min-width: 80rpx;
}

.team-name-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 15rpx 20rpx;
  font-size: 28rpx;
}

.team-members {
  margin-bottom: 20rpx;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #eee;
}

.member-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 10rpx;
}

.member-name {
  font-size: 28rpx;
  color: #333;
  margin-right: 15rpx;
}

.team-actions {
  display: flex;
  gap: 15rpx;
  align-items: center;
}

.new-member-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 15rpx 20rpx;
  font-size: 28rpx;
}

.add-member-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 26rpx;
  padding: 15rpx 25rpx;
  border-radius: 30rpx;
}

.nav-section {
  text-align: center;
  padding: 30rpx;
}

.nav-link {
  color: #fff;
  font-size: 28rpx;
  text-decoration: underline;
}