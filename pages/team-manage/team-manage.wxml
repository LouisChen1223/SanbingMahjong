<view class="container">
  <view class="header">
    <text class="title">队伍管理</text>
    <view class="header-btns">
      <view class="clear-btn" bindtap="clearAllData">清空数据</view>
    </view>
  </view>

  <view class="team-list">
    <text class="section-title">队伍列表</text>
    <view class="team-card" wx:for="{{teams}}" wx:key="_id">
      <view class="team-info-row">
        <text class="team-id">ID: {{item._id}}</text>
        <input class="team-name-input" placeholder="未命名" value="{{item.team_name}}" data-team-id="{{item._id}}" bindinput="onTeamNameInput" bindblur="updateTeamName" />
      </view>
      
      <view class="team-members">
        <text class="member-label">当前队员:</text>
        <view class="member-tags">
          <text class="member-name" wx:for="{{item.members}}" wx:for-item="member" wx:key="*this">{{member}} </text>
        </view>
      </view>

      <view class="team-actions">
        <input class="new-member-input" placeholder="输入新队员姓名" value="{{item.newMemberId}}" data-team-id="{{item._id}}" bindinput="onNewMemberInput" />
        <button class="add-member-btn" size="mini" data-team-id="{{item._id}}" bindtap="addMember">新增组员</button>
      </view>
    </view>
  </view>
</view>