/* pages/team-game/team-game.wxss */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.team-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.picker-btn {
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333;
}

.create-team-link {
  text-align: center;
  color: #667eea;
  font-size: 26rpx;
  margin-top: 20rpx;
}

.team-info {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.team-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.team-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.team-score {
  font-size: 28rpx;
  color: #667eea;
}

.team-members {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.member-label {
  font-weight: bold;
  margin-right: 10rpx;
}

.switch-team {
  text-align: center;
  color: #667eea;
  font-size: 26rpx;
}

.auth-warning {
  background: #fff3cd;
  border-radius: 10rpx;
  padding: 20rpx;
  text-align: center;
  color: #856404;
  margin-bottom: 30rpx;
}

.input-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.player-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.player-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.player-label {
  width: 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
}

.name-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.score-input-wrapper {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.sign-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.sign-btn.positive {
  background: #e8f5e9;
  color: #4caf50;
}

.sign-btn.negative {
  background: #ffebee;
  color: #f44336;
}

.score-input {
  width: 100rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  text-align: center;
}

.score-suffix {
  font-size: 24rpx;
  color: #999;
}

.settle-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin: 30rpx 0;
}

.result-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
}

.result-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.result-score {
  font-size: 32rpx;
  font-weight: bold;
}

.result-score[data-positive="true"] {
  color: #4caf50;
}

.result-score[data-positive="false"] {
  color: #f44336;
}

.nav-section {
  text-align: center;
  padding: 30rpx;
}

.nav-link {
  color: #fff;
  font-size: 28rpx;
  text-decoration: underline;
}

.back-home {
  display: inline-block;
  margin-left: 30rpx;
  padding: 16rpx 32rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 30rpx;
  color: #fff;
  font-size: 28rpx;
}

/* 底部导航栏 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1rpx solid #e8e8e8;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20rpx 0;
  z-index: 999;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx;
  width: 25%;
}

.nav-item.active {
  color: #667eea;
}

.nav-icon {
  font-size: 40rpx;
}

.nav-text {
  font-size: 24rpx;
}

/* 调整容器底部边距，避免被导航栏遮挡 */
.container {
  padding-bottom: 120rpx;
}