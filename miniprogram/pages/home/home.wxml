<!--home.wxml - 首页入口页面-->
<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">日麻计分</text>
    <text class="subtitle">选择对战模式</text>
  </view>

  <!-- 主要入口卡片区域 -->
  <view class="card-section">
    <!-- 个人竞技场卡片 -->
    <view class="mode-card individual-card" bindtap="goToIndividual">
      <view class="card-icon">🏆</view>
      <text class="card-title">个人竞技场</text>
      <text class="card-desc">个人赛模式，独立计分</text>
    </view>

    <!-- 五军对决卡片 -->
    <view class="mode-card team-card" bindtap="goToTeamGame">
      <view class="card-icon">⚔️</view>
      <text class="card-title">五军对决</text>
      <text class="card-desc">组队赛模式，A/B/C/D/E五队争霸</text>
    </view>
  </view>

  <!-- 快捷入口区域 -->
  <view class="quick-section">
    <view class="quick-item" bindtap="goToRank">
      <text class="quick-icon">📊</text>
      <text class="quick-text">排行榜</text>
    </view>
    <view class="quick-item" bindtap="goToHistory">
      <text class="quick-icon">📜</text>
      <text class="quick-text">历史记录</text>
    </view>
  </view>

  <!-- 底部战队管理入口 -->
  <view class="manage-section">
    <view class="manage-btn" bindtap="goToTeamManage">
      <text class="manage-icon">⚙️</text>
      <text class="manage-text">战队管理</text>
      <text class="manage-arrow">›</text>
    </view>
  </view>
</view>