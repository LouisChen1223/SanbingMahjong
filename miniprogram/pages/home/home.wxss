/* home.wxss - 首页样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

/* 页面标题 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
  padding-top: 40rpx;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 卡片区域 */
.card-section {
  margin-bottom: 40rpx;
}

.mode-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.2s;
}

.mode-card:active {
  transform: scale(0.98);
}

.individual-card {
  border-left: 8rpx solid #1AAD19;
}

.team-card {
  border-left: 8rpx solid #E64340;
}

.card-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #888888;
}

/* 快捷入口 */
.quick-section {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
  padding: 20rpx 0;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 40rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
}

.quick-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.quick-text {
  font-size: 24rpx;
  color: #ffffff;
}

/* 战队管理入口 */
.manage-section {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
}

.manage-btn {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 30rpx 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.manage-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.manage-text {
  flex: 1;
  font-size: 32rpx;
  color: #333333;
}

.manage-arrow {
  font-size: 40rpx;
  color: #cccccc;
}