/* rank.wxss - 排行榜页面样式 */

/* 页面容器 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
}

/* 页面标题 */
.header {
  padding: 30rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #e94560;
}

/* Tab切换栏 */
.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.05);
  margin: 0 20rpx;
  border-radius: 40rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #a0a0a0;
  border-radius: 32rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #e94560, #ff6b6b);
  color: #fff;
  font-weight: bold;
}

/* 加载状态 */
.loading {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #a0a0a0;
}

/* 滑动区域 */
.rank-swiper {
  flex: 1;
  margin-top: 20rpx;
}

.rank-scroll {
  height: 100%;
  padding: 0 20rpx 20rpx;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #a0a0a0;
  font-size: 28rpx;
}

/* 排行列表 */
.rank-list {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  overflow: hidden;
}

/* 排行项 */
.rank-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.rank-item:last-child {
  border-bottom: none;
}

/* 排名数字 */
.rank-num {
  width: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #a0a0a0;
  text-align: center;
}

/* 前三名特殊样式 */
.rank-item.top-1 .rank-num {
  color: #ffd700;
}

.rank-item.top-2 .rank-num {
  color: #c0c0c0;
}

.rank-item.top-3 .rank-num {
  color: #cd7f32;
}

/* 战队/成员徽章 */
.team-badge, .member-badge {
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  background: linear-gradient(135deg, #e94560, #ff6b6b);
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
  margin-right: 16rpx;
}

/* 排行信息 */
.rank-info {
  flex: 1;
  margin-left: 16rpx;
}

.rank-name {
  display: block;
  font-size: 30rpx;
  color: #fff;
  margin-bottom: 6rpx;
}

.rank-games {
  font-size: 22rpx;
  color: #a0a0a0;
}

/* 战队/成员统计 */
.team-stats, .member-stats {
  display: flex;
  gap: 16rpx;
}

.stat-item {
  font-size: 22rpx;
  color: #a0a0a0;
}

/* 积分显示 */
.rank-score {
  text-align: right;
  margin-left: 16rpx;
}

.score-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #e94560;
}

.score-label {
  font-size: 20rpx;
  color: #a0a0a0;
}

/* 前三名积分高亮 */
.rank-item.top-1 .score-value {
  color: #ffd700;
}

.rank-item.top-2 .score-value {
  color: #c0c0c0;
}

.rank-item.top-3 .score-value {
  color: #cd7f32;
}