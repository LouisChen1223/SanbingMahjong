/* team-manage.wxss - 战队管理页面样式 */

/* 页面容器 */
.container {
  padding: 30rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  min-height: 100vh;
}

/* 页面标题 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #e94560;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #a0a0a0;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #a0a0a0;
}

/* 战队容器 */
.teams-container {
  margin-top: 20rpx;
}

/* 战队横向滚动 */
.teams-scroll {
  white-space: nowrap;
  margin-bottom: 30rpx;
}

/* 战队卡片 */
.team-card {
  display: inline-block;
  width: 180rpx;
  padding: 20rpx;
  margin-right: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.team-card.active {
  background: rgba(233, 69, 96, 0.2);
  border-color: #e94560;
}

.team-badge {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  margin: 0 auto 10rpx;
  background: linear-gradient(135deg, #e94560, #ff6b6b);
  border-radius: 50%;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.team-name {
  display: block;
  font-size: 26rpx;
  color: #fff;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.team-count {
  font-size: 22rpx;
  color: #a0a0a0;
}

/* 战队详情 */
.team-detail {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 30rpx;
}

/* 操作按钮 */
.team-actions {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 30rpx;
}

.action-btn {
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  margin-left: 20rpx;
}

.rename-btn {
  background: rgba(255, 193, 7, 0.2);
  color: #ffc107;
}

.add-btn {
  background: rgba(76, 175, 80, 0.2);
  color: #4caf50;
}

/* 成员区域 */
.members-section {
  margin-top: 20rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 4rpx solid #e94560;
}

/* 空状态提示 */
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #a0a0a0;
  font-size: 26rpx;
}

/* 成员列表 */
.members-list {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
}

.member-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.member-item:last-child {
  border-bottom: none;
}

.member-name {
  font-size: 30rpx;
  color: #fff;
}

.member-stats {
  display: flex;
  gap: 20rpx;
}

.stat {
  font-size: 24rpx;
  color: #a0a0a0;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

/* 弹窗内容 */
.modal-content {
  width: 600rpx;
  background: #1a1a2e;
  border-radius: 20rpx;
  padding: 40rpx;
}

.modal-title {
  display: block;
  font-size: 32rpx;
  color: #fff;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 10rpx;
  padding: 0 20rpx;
  color: #fff;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 弹窗按钮 */
.modal-buttons {
  display: flex;
  margin-top: 40rpx;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.modal-btn.cancel {
  background: rgba(255, 255, 255, 0.1);
  color: #a0a0a0;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #e94560, #ff6b6b);
  color: #fff;
}